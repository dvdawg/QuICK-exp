# Normalize line endings so lab-PC (Windows) round-trips don't create phantom
# whole-file CRLF diffs. Text files are stored and checked out with LF.
* text=auto eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.ipynb text eol=lf

# Raw measurement data is consumed verbatim by external plotting software;
# leave it exactly as written by the `quick` Saver.
*.csv -text
